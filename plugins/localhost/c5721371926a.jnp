{"info":{"name":"Block Miner","description":"The bot finds specifc blocks and mines them. ","editedAt":1781286325947,"createdAt":1781127427347,"public":false,"language":"js","scriptType":"script","downloads":0,"theme":{"primaryColor":"#2193b0","secondaryColor":"#6dd5ed","accentColor":"#2193b0","gradientStart":"#2193b0","gradientEnd":"#6dd5ed","tagColor":"#6dd5ed"},"pluginId":"mq8la6mrw8lbei28659","config":[{"name":"General","options":[{"id":"username","label":"Username","type":"altSelect","required":true,"freeSolo":true},{"id":"blocks","label":"Blocks","type":"multiSelect","tooltip":"Write which blocks the bot should mine. The name must be the official minecraft item id. such as \"oak_log\" or \"diamond_ore\"","required":true,"options":["oak_log","diamond_ore"],"freeSolo":true},{"id":"chestLocation","label":"Chest location","type":"coordinate","tooltip":"The bot puts the items it collected into this chest. If you leave this empty, the bot leaves all items in the inventory."}],"collapsed":false},{"name":"Movement","options":[{"id":"allow1By1Towers","label":"Allow 1 by 1 towers","type":"switch","defaultValue":true},{"id":"allowDigging","label":"Allow digging","type":"switch","defaultValue":true},{"id":"scafoldingBlocks","label":"scafolding blocks","type":"multiSelect","options":["dirt","cobblestone"],"defaultValue":["cobblestone","dirt"],"freeSolo":true}],"collapsed":true}],"folder":"LocalProfile","banner":"https://i.ibb.co/gpwsfVQ/Block-Miner.webp"},"codeObf":"","signature":""}