{"info":{"name":"Kit Collector","description":"Collects your kits from all your alts","editedAt":1780050275111,"uploadedAt":null,"createdAt":1780048611706,"public":false,"type":"private","language":"js","scriptType":"action","flags":0,"downloads":0,"theme":{"primaryColor":"#2193b0","secondaryColor":"#6dd5ed","accentColor":"#2193b0","gradientStart":"#2193b0","gradientEnd":"#6dd5ed","tagColor":"#6dd5ed"},"settings":{},"pluginId":"mpqqzf5mlsgzkgxyk7d","banner":"https://i.ibb.co/23Sty5NH/kitcollector.png","config":[{"name":"General","options":[{"id":"gamemode","label":"Gamemode","type":"gamemodeSelect","required":true}],"collapsed":false},{"name":"Kits","options":[{"id":"kits","label":"Choose your kits","type":"multiSelect","tooltip":"To search for specific kits, enter a keyword such as 'skygod pvp kit' in the text field above and press enter. The bot will open kit window and search for the kits that matches the keyword you wrote. For instance, entering 'kit' would match 'Starter kit' and 'Food kit' but not 'k it'. For some gamemodes there's an 'extra' kit section where the bot needs to click on an item before it can access these kits. To deal with this issue, you can add a second keyword to every kit, for example 'once kit,extra kits' will open /kit window, click on an item that includes the name 'extra kits' and then click on 'once kit'.","required":true,"valueByFieldId":"gamemode","freeSolo":true},{"id":"command","label":"Command","type":"input","required":true,"valueByFieldId":"gamemode","inputType":"text","placeholder":"/kit","defaultValue":"/kit"}],"collapsed":true},{"name":"Transfer","options":[{"id":"itemTransfer","label":"Transfer mode","type":"select","required":true,"defaultValue":"gift","options":[{"label":"Keep items","value":"keep"},{"label":"Using /trade","value":"trade"},{"label":"Using gift","value":"gift"},{"label":"/trade with keys","value":"tradeWithKeys"}]},{"id":"username","label":"Transfer items to","type":"altSelect","freeSolo":true},{"id":"keyTypes","label":"Select keys (only for trade with keys)","type":"multiSelect","tooltip":"To determine the amount of keys to trade, specify the number of times the bot should click on each key. Keep in mind that trading a larger quantity may result in a longer transferring time. The format is as following <key type>,<amount> e.g. vote,10 means the bot tries to find the vote key slot and click 10 times on it.","valueByFieldId":"gamemode","options":["vote,10","rare,5","ultra,2","god,1"],"defaultValue":["vote,10","rare,5","ultra,2","god,1"],"freeSolo":true},{"id":"forceTradeKeys","label":"Force trade keys (only for trade with keys)","type":"switch","tooltip":"Trade keys even if you have no other items to trade","defaultValue":false,"labelChecked":"Always trade"},{"id":"trashItems","label":"Trash items","type":"multiSelect","tooltip":"Trash selected items before gifting. For example 'potion' will remove all items with 'potion' in its name.","valueByFieldId":"gamemode","options":["potion"],"freeSolo":true},{"id":"unequipArmor","label":"Unequip armor before transferring","type":"switch","valueByFieldId":"gamemode","defaultValue":false}],"collapsed":true},{"name":"Alts","options":[{"id":"altRange","label":"Alt range","type":"altRange","tooltip":"'Pick a starting and/or ending alt. The script walks the alt list from start → end. Leave both empty to run on every alt.","valueByFieldId":"gamemode"},{"id":"withTags","label":"Alts with tag","type":"tagsSelect","tooltip":"'Restrict the run to alts belonging to one or more tag groups (set in the Alts tab). Empty means no tag filter.","valueByFieldId":"gamemode"},{"id":"ignoreAlts","label":"Ignore alts","type":"altsSelect","valueByFieldId":"gamemode"},{"id":"withRanks","label":"Skip alts with no ranks","type":"switch","valueByFieldId":"gamemode","defaultValue":false,"labelChecked":"Skip no rank alts"}],"collapsed":true}],"folder":"JartexProfile"},"codeObf":"","signature":""}