{"info":{"name":"Book sorter","description":"Opens up enchanter, buys books, opens them and removes the bad ones. ","editedAt":1781286363186,"uploadedAt":null,"createdAt":1780436076733,"public":false,"type":"private","language":"js","scriptType":"script","flags":0,"downloads":0,"theme":{"primaryColor":"#2193b0","secondaryColor":"#6dd5ed","accentColor":"#2193b0","gradientStart":"#2193b0","gradientEnd":"#6dd5ed","tagColor":"#6dd5ed"},"settings":{},"pluginId":"mpx5o52zjqnm6uebbj","config":[{"name":"General","options":[{"id":"gamemode","label":"Gamemode","type":"gamemodeSelect","required":true},{"id":"username","label":"Username","type":"altSelect","required":true}],"collapsed":false},{"name":"Gifts","options":[{"id":"giftTo","label":"Gift items to","type":"altSelect","required":true},{"id":"pvFillAmount","label":"Amount of books before gifting","type":"input","tooltip":"The amount of books that should be in the pv before gifting them to main account. If 0, it will fill up the entire pv, if you set it to 1 then it will not use pvs.","inputType":"number"},{"id":"trashUnwantedBooks","label":"Handle unwanted books","type":"switch","defaultValue":false,"labelChecked":"Trash books","labelUnchecked":"Tinker books"},{"id":"trashDust","label":"Trash dust","type":"switch","defaultValue":false,"labelChecked":"Trash dust","labelUnchecked":"Gift dust"}],"collapsed":true},{"name":"Books","options":[{"id":"bookType","label":"Book type","type":"select","required":true,"options":[{"label":"Basic","value":"basic"},{"label":"Rare","value":"rare"},{"label":"Mythical","value":"mythical"},{"label":"Legendary","value":"legendary"},{"label":"Immortal","value":"immortal"},{"label":"Galaxy","value":"galaxy"},{"label":"Common","value":"common"},{"label":"Uncommon","value":"uncommon"},{"label":"Epic","value":"epic"},{"label":"Unique","value":"unique"}],"freeSolo":true},{"id":"books","label":"Books","type":"list","required":true,"valueByFieldId":"bookType","addLabel":"Add book","fields":[{"key":"book","label":"Book","type":"input","inputType":"text","placeholder":"example: voodoo"},{"key":"minLevel","label":"Min book level","type":"input","inputType":"number","placeholder":"optional"},{"key":"pv","label":"Pv","type":"input","inputType":"number","placeholder":"optional"}]}],"collapsed":true}],"folder":"JartexProfile","banner":"https://i.ibb.co/jZ4y0LLN/booksorter.webp"},"codeObf":"","signature":""}