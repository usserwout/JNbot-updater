{"info":{"name":"Kit Collector","description":"Collects your kits from all your alts","editedAt":1780050275111,"uploadedAt":null,"createdAt":1780048611706,"public":false,"type":"private","language":"js","scriptType":"action","flags":0,"downloads":0,"theme":{"primaryColor":"#2193b0","secondaryColor":"#6dd5ed","accentColor":"#2193b0","gradientStart":"#2193b0","gradientEnd":"#6dd5ed","tagColor":"#6dd5ed"},"settings":{},"pluginId":"mpqqzf5mlsgzkgxyk7d","banner":"https://i.ibb.co/23Sty5NH/kitcollector.png","config":[{"name":"General","options":[{"id":"gamemode","label":"Gamemode","type":"gamemodeSelect","required":true}],"collapsed":false},{"name":"Kits","options":[{"id":"kits","label":"Choose your kits","type":"multiSelect","tooltip":"To search for specific kits, enter a keyword such as 'skygod pvp kit' in the text field above and press enter. The bot will open kit window and search for the kits that matches the keyword you wrote. For instance, entering 'kit' would match 'Starter kit' and 'Food kit' but not 'k it'. For some gamemodes there's an 'extra' kit section where the bot needs to click on an item before it can access these kits. To deal with this issue, you can add a second keyword to every kit, for example 'once kit,extra kits' will open /kit window, click on an item that includes the name 'extra kits' and then click on 'once kit'.","required":true,"valueByFieldId":"gamemode","freeSolo":true},{"id":"command","label":"Command","type":"input","required":true,"valueByFieldId":"gamemode","inputType":"text","placeholder":"/kit","defaultValue":"/kit"}],"collapsed":true},{"name":"Transfer","options":[{"id":"itemTransfer","label":"Transfer mode","type":"select","required":true,"defaultValue":"gift","options":[{"label":"Keep items","value":"keep"},{"label":"Using /trade","value":"trade"},{"label":"Using gift","value":"gift"},{"label":"/trade with keys","value":"tradeWithKeys"}]},{"id":"username","label":"Transfer items to","type":"altSelect","freeSolo":true},{"id":"keyTypes","label":"Select keys (only for trade with keys)","type":"multiSelect","tooltip":"To determine the amount of keys to trade, specify the number of times the bot should click on each key. Keep in mind that trading a larger quantity may result in a longer transferring time. The format is as following <key type>,<amount> e.g. vote,10 means the bot tries to find the vote key slot and click 10 times on it.","valueByFieldId":"gamemode","options":["vote,10","rare,5","ultra,2","god,1"],"defaultValue":["vote,10","rare,5","ultra,2","god,1"],"freeSolo":true},{"id":"forceTradeKeys","label":"Force trade keys (only for trade with keys)","type":"switch","tooltip":"Trade keys even if you have no other items to trade","defaultValue":false,"labelChecked":"Always trade"},{"id":"trashItems","label":"Trash items","type":"multiSelect","tooltip":"Trash selected items before gifting. For example 'potion' will remove all items with 'potion' in its name.","valueByFieldId":"gamemode","options":["potion"],"freeSolo":true},{"id":"unequipArmor","label":"Unequip armor before transferring","type":"switch","valueByFieldId":"gamemode","defaultValue":false}],"collapsed":true},{"name":"Alts","options":[{"id":"altRange","label":"Alt range","type":"altRange","tooltip":"'Pick a starting and/or ending alt. The script walks the alt list from start → end. Leave both empty to run on every alt.","valueByFieldId":"gamemode"},{"id":"withTags","label":"Alts with tag","type":"tagsSelect","tooltip":"'Restrict the run to alts belonging to one or more tag groups (set in the Alts tab). Empty means no tag filter.","valueByFieldId":"gamemode"},{"id":"ignoreAlts","label":"Ignore alts","type":"altsSelect","valueByFieldId":"gamemode"},{"id":"withRanks","label":"Skip alts with no ranks","type":"switch","valueByFieldId":"gamemode","defaultValue":false,"labelChecked":"Skip no rank alts"}],"collapsed":true}],"folder":"JartexProfile"},"code":{"code":"const {script, BotMachine} = require(\"jnbot\")\n\nasync function main(bot, scriptOptions) {\n\n  let hasInvalidSettings = false\n  if (scriptOptions.itemTransfer !== \"keep\" && !scriptOptions.username) {\n    script.optionError({ field: \"username\", message: \"Enter an account to transfer the gkits to\" })\n    hasInvalidSettings = true\n  }\n\n  if (hasInvalidSettings) {\n    script.stop()\n  }\n\n\n  const botUsername = bot.username\n\n  const {\n    forceTradeKeys,\n    keys,\n    transferMode,\n    username,\n    unequipArmor,\n    command,\n    trashItems,\n  } = scriptOptions;\n\n\n  let kitsByWindow = {};\n  if (scriptOptions.kits) {\n    scriptOptions.kits = scriptOptions.kits.map((k) => {\n      if (typeof k !== 'string') k = '';\n      let [kitName, extraClick] = k.split(',');\n      extraClick ||= '';\n      extraClick = extraClick.toLowerCase();\n      kitsByWindow[extraClick] ??= [];\n      kitsByWindow[extraClick].push(kitName);\n      return {\n        kitName: kitName.toLowerCase(),\n        extraClick: extraClick,\n      };\n    });\n  }\n  kitsByWindow = Object.entries(kitsByWindow);\n\n\n  let kitsToOpen = JSON.parse(JSON.stringify(kitsByWindow)); // deep copy\n  let itemsClickedOn = {};\n  kitsToOpen.forEach(([k]) => (itemsClickedOn[k] = []));\n\n\n  return new Promise((resolve) => {\n    new BotMachine([\n      {\n        name: 'Unequipping armor',\n        when: ({ bot }) =>\n          unequipArmor &&\n          !bot.currentWindow &&\n          bot.inventory.emptySlotCount() > 5 &&\n          bot.inventory.slots\n            .slice(\n              bot.inventory.inventoryStart - 5,\n              bot.inventory.inventoryStart,\n            )\n            .some((slot) => slot),\n        run: async ({ bot }) => {\n          bot.openInventory(); // we're moving items, so we need to open the inventory\n          await bot.waitForTicks(5);\n          for (\n            let i = bot.inventory.inventoryStart - 5;\n            i < bot.inventory.inventoryStart;\n            i++\n          ) {\n            const slot = bot.inventory.slots[i];\n            if (!slot) continue;\n            const moveTo = bot.inventory.firstEmptySlotRange(\n              bot.inventory.inventoryStart,\n              bot.inventory.inventoryEnd,\n            );\n            if (moveTo === -1) break;\n            bot.clickWindow(slot.slot, 0, 0);\n            await bot.waitForTicks(5);\n            bot.clickWindow(moveTo, 0, 0);\n            await bot.waitForTicks(5);\n          }\n        },\n      },\n\n      {\n        name: 'Trashing items',\n        when: ({ bot }) =>\n          ((trashItems.length && bot.inventory.emptySlotCount() < 8) ||\n            kitsToOpen.length === 0) &&\n          getItemsToTrash(bot).length > 0,\n\n        run: async ({ bot }) => {\n          if (bot.currentWindow) {\n            bot.closeWindow(bot.currentWindow);\n            await bot.onceWithTimeout('windowClose', 5);\n            if (bot.currentWindow) return;\n          }\n\n          await bot.transferItems.trash({\n            ignore: ['clock'],\n            keep: true,\n            itemFilter: (slot) => itemTrashFilter(slot, bot),\n          });\n        },\n      },\n\n      {\n        name: 'Depositing items',\n        when: ({ bot }) =>\n          bot.inventory.emptySlotCount() < 8 || kitsToOpen.length === 0,\n        run: async ({ bot, machine }) => {\n          if (transferMode === 1 && bot.username === username) {\n            global.log(\n              'Skipping depositing items for main account',\n              'warning',\n            );\n            machine.stop();\n            return;\n          }\n\n          if (bot.currentWindow) {\n            bot.closeWindow(bot.currentWindow);\n            global.log('Closing current window...');\n            await bot.waitForTicks(5);\n            if (bot.currentWindow) return;\n          }\n\n          if (transferMode) {\n            await bot.transferItems(transferMode, {\n              username,\n              ignore: ['clock'],\n              keys,\n              forceTradeKeys: forceTradeKeys,\n              keep: false,\n            });\n          }\n\n          if (bot.inventory.emptySlotCount() < 8) {\n            global.log(\n              `[${bot.username}] Skipping this alt because inventory has fewer than 8 empty slots, please clear inventory. Skipping alt...`,\n              'warning',\n            );\n            machine.stop();\n            return;\n          }\n          if (kitsToOpen.length === 0) {\n            machine.stop(); // Finished!\n          }\n        },\n      },\n      {\n        name: 'Opening kit window',\n        when: ({ bot, state }) =>\n          !bot.currentWindow || !state.openedWindow,\n        run: async ({ bot, state }) => {\n          if (bot.currentWindow) {\n            bot.closeWindow(bot.currentWindow);\n            global.log('Closing current window: ' + bot.getWindowTitle());\n            await bot.onceWithTimeout('windowClose', 5);\n          }\n          // const defaultRank =\n          //   global.appSettings?.server === 'pikanetwork'\n          //     ? 'member'\n          //     : 'player';\n\n          // const rank =\n          //   (bot.getRank() ?? '').trim().toLowerCase() || defaultRank;\n          // The reason we add the rank to the command to go immidiatly to the rank kit window. -> no need to navigate through other windows\n          await bot.openWindow(command, { timeout: 10_000 });\n          if (!bot.currentWindow) {\n            // Alt is in bugged state where it's at /hub\n            console.warn(\"Alt is probably bugged in /hub \")\n            //bot.chat('/server ' + collectOptions.gamemode); // Idk if this will fix it, it tries to join the gamemode\n            await bot.waitForTicks(20)\n            return\n          }\n\n          state.openedWindow = true;\n          const slotName = kitsToOpen[0][0];\n          if (slotName && slotName.length > 0) {\n            let slots = findSlots(bot, slotName);\n\n            if (slots.length === 0) {\n              console.log(\n                `[${bot.username}] Unable to find slot with name '${slotName}', cannot open gkits: ${kitsToOpen[0][1].join(', ')}`,\n                'error',\n              );\n\n              return;\n            }\n            if (slots.length > 1) {\n              console.log(\n                `[${bot.username}] Found multiple slots with name '${slotName}': ${slots.map((s) => s.name).join(', ')}, be more specific! Clicking on the first one...`,\n                'warning',\n              );\n            }\n            slots = slots[0];\n\n            bot.clickWindow(slots.slot, 0, 0);\n            await bot.onceWithTimeout('windowOpen', 5);\n          }\n        },\n      },\n      {\n        name: 'Clicking on kit',\n        when: () => true,\n        run: async ({ bot }) => {\n          if (kitsToOpen.length === 0)\n            return bot.currentWindow && bot.closeWindow(bot.currentWindow);\n          if (kitsToOpen[0][1].length === 0) {\n            kitsToOpen.shift();\n            return bot.currentWindow && bot.closeWindow(bot.currentWindow);\n          }\n\n          const itemName = kitsToOpen[0][1][0];\n          const windowName = kitsToOpen[0][0];\n\n          let slots = findSlots(bot, itemName);\n          if (slots.length === 0) {\n            global.log(\n              `[${bot.username}] Unable to find slot for '${itemName}'`,\n              'error',\n            );\n\n            return;\n          }\n\n          // filter out the slots we already clicked on or the ones that are not unlocked\n          slots = slots.filter((slot) => {\n            if (itemsClickedOn[windowName].includes(slot.slot)) return false;\n            const lore = (slot.lore ?? '').toLowerCase().replace(/§./g, '');\n            if (\n              lore.includes('you are not allowed to claim this kit') ||\n              lore.includes('you can not use this kit')\n            ) {\n              global.log(\n                `[${bot.username}] Skipping '${slot.name}' because kit is not unlocked`,\n                'warning',\n              );\n              itemsClickedOn[windowName].push(slot.slot);\n              return false;\n            }\n            return true;\n          });\n\n          if (slots.length < 2) {\n            kitsToOpen[0][1].shift();\n            if (kitsToOpen[0][1].length === 0) {\n              kitsToOpen.shift();\n            }\n          }\n          if (slots.length === 0) {\n            bot.closeWindow(bot.currentWindow);\n            await bot.onceWithTimeout('windowClose', 5);\n            return;\n          }\n\n          const slot = slots[0];\n          itemsClickedOn[windowName].push(slot.slot);\n\n          global.log(\n            `[${bot.username}] Claiming: ${itemName} (clicking on ${slot.name})`,\n          );\n\n          bot.clickWindow(slot.slot, 0, 0);\n          await bot.onceWithTimeout('windowClose', 5);\n\n          if (bot.currentWindow) {\n            await bot.waitForTicks(10);\n            if (bot.currentWindow) bot.clickWindow(slot.slot, 0, 0);\n          }\n          await bot.waitForTicks(1);\n        },\n      },\n\n    ], {\n      bot,\n      join: {\n        joinOptions: { username: botUsername },\n        gamemode: scriptOptions.gamemode,\n      },\n      state: { needToOpen: null }\n    }).onFinish(() => {\n      resolve()\n    }).start()\n  })\n\n\n\n  function findSlots(bot, targetName) {\n    if (!bot.currentWindow) return [];\n    let slots = [];\n\n    for (let i = 0; i < bot.currentWindow.inventoryStart; i++) {\n      let slot = bot.currentWindow.slots[i];\n      if (!slot) continue;\n      const info = bot.itemInfo(slot);\n      const itemName = info.name.toLowerCase().replace(/§./g, '');\n      if (itemName.includes(targetName)) {\n        slots.push({\n          slot: slot.slot,\n          name: itemName,\n          lore: info.info,\n        });\n      }\n    }\n\n    return slots;\n\n  }\n\n  function itemTrashFilter(slot, bot) {\n    if (!slot) return false;\n    const itemName = (\n      bot.itemInfo(slot).name ||\n      slot.displayName ||\n      ''\n    ).toLowerCase();\n    if (!itemName.length) return false;\n    return trashItems.some((item) => itemName.includes(item));\n  }\n\n  function getItemsToTrash(bot) {\n    let window = bot.currentWindow ?? bot.inventory;\n    let itemsToTrash = [];\n    let itemNames = [];\n    for (let i = window.inventoryStart; i < window.inventoryEnd; i++) {\n      const slot = window.slots[i];\n      if (!slot) continue;\n      if (itemTrashFilter(slot, bot)) {\n        itemNames.push(bot.itemInfo(slot).name || slot.displayName || '');\n        itemsToTrash.push(slot);\n      }\n    }\n    if (itemsToTrash.length !== 0) {\n      log(\n        `[${bot.username}]: Trashing following items: ${itemNames.join(', ')}`,\n      );\n    }\n\n    return itemsToTrash;\n  }\n\n}\n\n\n\n\n\n"},"signature":""}