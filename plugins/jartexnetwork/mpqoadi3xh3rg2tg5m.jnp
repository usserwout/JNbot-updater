{"info":{"name":"AutoTrader","description":"Automatically accepts trades","editedAt":1780219083460,"uploadedAt":null,"createdAt":1780044083932,"public":false,"type":"private","language":"js","scriptType":"script","flags":0,"downloads":0,"theme":{"primaryColor":"#2193b0","secondaryColor":"#6dd5ed","accentColor":"#2193b0","gradientStart":"#2193b0","gradientEnd":"#6dd5ed","tagColor":"#6dd5ed"},"settings":{},"pluginId":"mpqoadi3xh3rg2tg5m","config":[{"name":"General","options":[{"id":"gamemode","label":"Gamemode","type":"gamemodeSelect","required":true},{"id":"username","label":"Username","type":"altSelect","required":true,"freeSolo":false},{"id":"startingPv","label":"Starting pv","type":"input","tooltip":"Which pv should the bot start with putting item in it","required":true,"inputType":"text","defaultValue":"1"}],"collapsed":false}],"banner":"https://i.ibb.co/N6f2N35Z/auto-Trader.png","folder":"JartexProfile"},"code":{"code":"\nconst {BotMachine, script} = require(\"jnbot\")\n\nconst options = script.settings\n\n\nnew BotMachine([\n  {\n    name: 'Setting up trade listener',\n    when: () => true,\n    once: true,\n    run: async ({ bot, state }) => {\n      bot.on('message', (m) => {\n        const clickEvent =\n          m?.extra?.[0]?.clickEvent || m?.json?.extra?.[0]?.clickEvent;\n        if (\n          clickEvent &&\n          clickEvent.action === 'run_command' &&\n          clickEvent.value.startsWith('/trade')\n        ) {\n          console.log('Trade offer received');\n          state.__tradeOffer = clickEvent.value;\n        }\n      });\n    },\n  },\n  {\n    name: 'Pv full, closing pv',\n    when: ({ bot }) =>\n      bot.currentWindow &&\n      bot.getWindowTitle().toLowerCase().includes('vault') &&\n      bot.currentWindow.firstEmptyContainerSlot() == null,\n    run: async ({ bot, state }) => {\n      state.pvCount++;\n      bot.closeWindow(bot.currentWindow);\n      await bot.waitForTicks(5);\n    },\n  },\n  {\n    name: \"Depositing items to pv\",\n    when: ({ bot }) => bot.currentWindow &&\n      bot.getWindowTitle().toLowerCase().includes('vault'),\n    run: async ({ bot }) => {\n      await bot.transferItems(3, {\n        ignore: ['clock'],\n        timeout: 60_000,\n        itemFilter:\n          options.ignoreItems.length > 0\n            ? (item) => {\n              let itemName = item.name.toLowerCase().replace(/§./g, '');\n              return !options.ignoreItems.some((e) =>\n                itemName.includes(e),\n              );\n            }\n            : undefined,\n      });\n      if (bot.currentWindow) bot.closeWindow(bot.currentWindow);\n    }\n  },\n\n  {\n    name: 'Searching for accept slot',\n    when: ({ bot, state }) =>\n      !state.__acceptSlot && hasTradeWindowOpened(bot),\n    run: async ({ bot, state }) => {\n      for (let i = 0; i < bot.currentWindow.inventoryStart; i += 9) {\n        for (let j = 0; j < 4; j++) {\n          const slot = bot.currentWindow.slots[i + j];\n          if (slot && slot.name.includes('glass')) {\n            state.__acceptSlot = i + j;\n            return;\n          }\n        }\n      }\n      console.log(\"Couldn't find accept slot, using default\", 'warning');\n      state.__acceptSlot = 45;\n    },\n    once: true,\n  },\n  {\n    name: 'Accepting trade',\n    when: ({ bot, state }) =>\n      hasTradeWindowOpened(bot) &&\n      traderAccepted(bot, state) &&\n      !hasAcceptedTrade(bot, state),\n    run: async ({ bot, state }) => {\n      bot.clickWindow(state.__acceptSlot, 0, 0);\n      await bot.waitForTicks(20);\n    },\n  },\n  {\n    name: 'Waiting for trade to complete',\n    when: ({ bot }) => hasTradeWindowOpened(bot),\n    run: async ({ bot }) => {\n      await bot.waitForTicks(20);\n    },\n  },\n  {\n    name: 'Opening pv',\n    when: ({ bot }) => {\n      let sum = 0;\n      for (\n        let i = bot.inventory.inventoryStart;\n        i < bot.inventory.inventoryEnd;\n        i++\n      ) {\n        if (bot.inventory.slots[i] === null) {\n          sum++;\n          if (sum >= 12) return false;\n        }\n      }\n      return true;\n    },\n    run: async ({ bot, state }) => {\n      console.log('Opening pv ' + state.pvCount);\n      await bot.openWindow('/pv ' + state.pvCount);\n    },\n  },\n  {\n    name: 'Checking if trade offer is available',\n    when: ({ state }) => !!state.__tradeOffer,\n    run: async ({ bot, state }) => {\n      bot.chat(state.__tradeOffer);\n      state.__tradeOffer = null;\n      await bot.waitForTicks(15);\n    },\n  },\n\n], {\n  join: { joinOptions: { username: options.username, version: \"1.16.5\" }, gamemode: options.gamemode },\n  delay: 250,\n  debug:true\n}).start()\n\n\n\nfunction hasTradeWindowOpened(bot) {\n  if (!bot.currentWindow) return false;\n  const winTitle = bot.getWindowTitle().toLowerCase();\n  return winTitle.includes('trade') || winTitle.includes('trading');\n}\n\n\nfunction hasAcceptedTrade(bot, targets) {\n  const slot = bot.currentWindow.slots[targets.__acceptSlot];\n  return slot && isGreenGlass(slot);\n}\n\nfunction isGreenGlass(slot) {\n  return (\n    slot.name === 'green_stained_glass_pane' ||\n    (slot.name.includes('glass') &&\n      (slot.metadata === 5 || slot.metadata === 13))\n  );\n}\n\nfunction traderAccepted(bot, targets) {\n  const slot = bot.currentWindow.slots[targets.__acceptSlot + 6];\n  return slot && isGreenGlass(slot);\n}\n\n"},"signature":""}