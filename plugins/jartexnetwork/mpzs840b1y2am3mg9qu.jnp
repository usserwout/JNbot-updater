{"info":{"name":"AFK","description":"AFK with your alts","editedAt":1780595685498,"uploadedAt":null,"createdAt":1780594892363,"public":false,"type":"private","language":"js","scriptType":"script","flags":0,"downloads":0,"theme":{"primaryColor":"#2193b0","secondaryColor":"#6dd5ed","accentColor":"#2193b0","gradientStart":"#2193b0","gradientEnd":"#6dd5ed","tagColor":"#6dd5ed"},"settings":{},"pluginId":"mpzs840b1y2am3mg9qu","banner":"https://i.ibb.co/hF64wGM2/afk.png","config":[{"name":"General","options":[{"id":"gamemode","label":"Gamemode","type":"gamemodeSelect","required":true},{"id":"alts","label":"Alts","type":"altsSelect","required":true,"valueByFieldId":"gamemode"},{"id":"afkCommand","label":"Write /afk in chat","type":"switch","defaultValue":false},{"id":"physicsEnabled","label":"Enable bot physics","type":"switch","defaultValue":false}],"collapsed":false}],"folder":"JartexProfile"},"code":{"code":"const { BotMachine, script } = require(\"jnbot\")\n\n\n\nasync function joinWithBot(username,scriptOptions) {\n  new BotMachine([\n    {\n\n      once: true,\n      name: 'Set status to away',\n      when: ({ bot }) => bot?.isOnline(),\n      run: ({ bot }) => {\n        bot.chat('/status away');\n        if (scriptOptions.afkCommand) bot.chat('/afk');\n        setTimeout(() => {\n          bot.physicsEnabled = scriptOptions.physicsEnabled ?? true;\n        }, 1000);\n      },\n    }\n  ], {\n    options: { username },\n    join: { gamemode: scriptOptions.gamemode },\n    delay: 750\n  }).start()\n}\n\nasync function main() {\n\n  const scriptOptions = script.settings\n  const alts = scriptOptions.alts\n\n  if(alts.length === 0) {\n    script.optionError({field: \"alts\", message: \"You need to join with at least 1 alt\"})\n    script.stop()\n  }\n\n  for (const username of alts) {\n    console.log(\"Joining with \" + username)\n    joinWithBot(username, scriptOptions)\n    await sleep(1000)\n  }\n\n}\n\nfunction sleep(x) {\n  return new Promise((resolve) => setTimeout(resolve, x))\n}\n\nmain()"},"signature":""}