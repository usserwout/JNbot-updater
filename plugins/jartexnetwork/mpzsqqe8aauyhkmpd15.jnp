{"info":{"name":"AltScanner","description":"Scan your alts for gkits","editedAt":1780597246335,"uploadedAt":null,"createdAt":1780595761184,"public":false,"type":"private","language":"js","scriptType":"script","flags":0,"downloads":0,"theme":{"primaryColor":"#2193b0","secondaryColor":"#6dd5ed","accentColor":"#2193b0","gradientStart":"#2193b0","gradientEnd":"#6dd5ed","tagColor":"#6dd5ed"},"settings":{},"pluginId":"mpzsqqe8aauyhkmpd15","folder":"JartexProfile","banner":"https://i.ibb.co/gMk0Z0cp/altscanner.png","config":[{"name":"General","options":[{"id":"gamemodes","label":"Gamemodes","type":"gamemodeSelect","required":true,"multiple":true},{"id":"ranksOnly","label":"Ranks only","type":"switch","defaultValue":false}],"collapsed":false},{"name":"Alts","options":[{"id":"altRange","label":"Alt range","type":"altRange"},{"id":"withTags","label":"Tag groups","type":"tagsSelect"},{"id":"ignoreAlts","label":"Ignore alts","type":"altsSelect"}],"collapsed":true}]},"code":{"code":"const { BotMachine, script, AltWith } = require(\"jnbot\")\nconst axios = require(\"axios\")\n\n\nasync function main() {\n\n    if (script.settings.gamemodes.length === 0) {\n        script.optionError({ field: \"gamemodes\", message: \"Select at least 1 gamemode\" })\n        script.stop()\n    }\n\n    let alts = {}\n    for await (const bot of script.forEachAlt(script.getAlts(), script.settings)) {\n        const username = bot.alt.username\n        const altResults = await scanAlt(bot)\n        alts[username] = altResults.data\n    }\n\n    script.requestAltUpdate(alts)\n    script.stop()\n    \n}\n\n/**\n * \n * @param {Bot} bot \n * @returns {Promise<{alt: Alt, data: {ranks: Object, gkits: Object}}>}\n */\nasync function scanAlt(bot) {\n\n    const gamemodes = script.settings.gamemodes.map(gm => gm.toLowerCase())\n\n    return new Promise((resolve) => {\n        new BotMachine([{\n            name: \"Joining gamemode\",\n            when: () => bot.getGamemode()?.toLowerCase().includes(gamemodes[bot.state.gamemodeCounter]) === false,\n            run: async ({ bot, state }) => {\n                await bot.join(gamemodes[state.gamemodeCounter])\n            }\n        }, {\n            name: \"Open gkit menu\",\n            when: ({ bot }) => !bot.currentWindow,\n            run: async ({ bot }) => {\n                await bot.openWindow(\"/gkit\")\n            }\n        }, {\n            name: \"Closing window\",\n            when: ({ bot }) => {\n                const title = bot.getWindowTitle()?.toLowerCase();\n                return (\n                    !title.includes('gkit') &&\n                    !title.includes('classes') &&\n                    !title.includes('\"color\":\"white\"')\n                );\n            },\n            run: async ({ bot }) => {\n                bot.closeWindow(bot.currentWindow);\n                await bot.waitForTicks(10);\n            },\n        }, {\n            name: 'Counting gkits',\n            when: ({ state }) =>\n                !Array.isArray(state.gkits[gamemodes[state.gamemodeCounter]]),\n            action: async ({ bot, state }) => {\n                let gkits = [];\n                let seen = {};\n                for (let i = 0; i < bot.currentWindow.inventoryStart - 5; i++) {\n                    const slot = bot.currentWindow.slots[i];\n                    if (\n                        !slot ||\n                        slot?.name === 'red_stained_glass_pane' ||\n                        slot?.name === 'gray_stained_glass_pane' ||\n                        slot?.name === 'arrow'\n                    )\n                        continue;\n                    let item = bot.itemInfo(slot);\n                    if (\n                        item?.info?.includes('You do not have permission!') ||\n                        item?.info?.includes('You do not own this') ||\n                        item?.info?.includes('Click to purchase this ')\n                    )\n                        continue;\n                    if (!item?.info?.includes('UNLOCKED') && i % 9 === 0) continue; // Skip the items on the first column\n                    let itemName = item.name.toLowerCase().replace(/§./g, '');\n                    if (itemName.includes('next page')) continue;\n\n                    if (gamemode === 'survival' && slot.name) {\n                        if (item.name in seen) continue;\n                        seen[item.name] = true;\n                    }\n                    if (itemName === 'crate keys' || itemName === 'cratekeys')\n                        itemName = 'keys';\n                    else if (itemName === 'newyears') itemName = 'new years';\n                    else if (\n                        itemName &&\n                        !JNdataServer[gamemode]?.gkits?.hasOwnProperty(itemName)\n                    ) {\n                        console.log(\n                            `[${bot.username}]: Unknown gkit '${itemName}' (${gamemode})`,\n                        );\n                    }\n                    if (itemName) gkits.push(itemName);\n                }\n\n            },\n        }, {\n            name: 'Finishing gkit scan',\n            when: () => true,\n            run: async ({ bot, state, botMachine }) => {\n\n                const nextGkitSlot = bot.getNextGkitPageSlot(bot);\n\n                if (nextGkitSlot >= 0) {\n                    bot.clickWindow(nextGkitSlot, 0, 0);\n                    await bot.waitForTicks(10);\n                    return;\n                }\n                \n                state.gamemodeCounter++;\n                if (state.gamemodeCounter >= gamemodes.length) {\n                    if (bot.currentWindow) bot.closeWindow(bot.currentWindow);\n                    botMachine.stop();\n                }\n            },\n        },], {\n            state: { gamemodeCounter: 0, ranks: {}, gkits: {} },\n            bot,\n            options: { version: \"1.20.11\" }\n        }).onFinish((state) => {\n            resolve({\n                ranks: state.ranks,\n                gkits: state.gkits,\n            })\n        }).start()\n\n\n    })\n\n}\n\n\nasync function fetchRanks(username) {\n    if (!username) return null;\n    try {\n        const response = await axios.get(\n            `https://stats.jartexnetwork.com/api/profile/${username}`,\n        );\n        const data = response.data;\n\n        const ranks = {};\n        const gamemodeList = gamemodes.map((g) =>\n            g.toLowerCase().replaceAll(' ', ''),\n        );\n\n        const apiRanks = {};\n\n        data.ranks?.forEach((r) => {\n            const server = r.server.toLowerCase().replaceAll(' ', '');\n            apiRanks[translateGm[server] ?? server] = r;\n        });\n\n        if (data.ranks?.length) {\n            console.log(\n                `[${username}]: Has a rank in gamemodes: ${Object.keys(apiRanks).join(', ')}`,\n            );\n        }\n\n        for (const jnbotGm of gamemodeList) {\n            const apiRank = apiRanks[jnbotGm];\n            if (!apiRank) {\n                ranks[jnbotGm] = null;\n                continue;\n            }\n            const rank = apiRank.displayName?.toLowerCase();\n            if (!rank?.length) {\n                console.error(\"Found rank without name, shouldn't happen\");\n                continue;\n            }\n\n            if (rank && !JNdataServer[jnbotGm]?.ranks?.hasOwnProperty(rank)) {\n                global.log(\n                    `[${username}]: Unknown rank '${rank.toLowerCase()}' (${jnbotGm})`,\n                );\n            }\n\n            ranks[jnbotGm] = rank;\n            global.log(`[${username}]: Detected rank ${rank} (${jnbotGm})`);\n        }\n\n        results.ranks = ranks;\n    } catch (err) {\n        console.log(err);\n        return null;\n    }\n\n}\n\nmain()"},"signature":""}