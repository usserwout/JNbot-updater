{"info":{"name":"Book sorter","description":"Opens up enchanter, buys books, opens them and removes the bad ones. ","editedAt":1780593534094,"uploadedAt":null,"createdAt":1780436076733,"public":false,"type":"private","language":"js","scriptType":"script","flags":0,"downloads":0,"theme":{"primaryColor":"#2193b0","secondaryColor":"#6dd5ed","accentColor":"#2193b0","gradientStart":"#2193b0","gradientEnd":"#6dd5ed","tagColor":"#6dd5ed"},"settings":{},"pluginId":"mpx5o52zjqnm6uebbj","config":[{"name":"General","options":[{"id":"gamemode","label":"Gamemode","type":"gamemodeSelect","required":true},{"id":"username","label":"Username","type":"altSelect","required":true}],"collapsed":false},{"name":"Gifts","options":[{"id":"giftTo","label":"Gift items to","type":"altSelect","required":true},{"id":"pvFillAmount","label":"Amount of books before gifting","type":"input","tooltip":"The amount of books that should be in the pv before gifting them to main account. If 0, it will fill up the entire pv, if you set it to 1 then it will not use pvs.","inputType":"number"},{"id":"trashUnwantedBooks","label":"Handle unwanted books","type":"switch","defaultValue":false,"labelChecked":"Trash books","labelUnchecked":"Tinker books"},{"id":"trashDust","label":"Trash dust","type":"switch","defaultValue":false,"labelChecked":"Trash dust","labelUnchecked":"Gift dust"}],"collapsed":true},{"name":"Books","options":[{"id":"bookType","label":"Book type","type":"select","required":true,"options":[{"label":"Basic","value":"basic"},{"label":"Rare","value":"rare"},{"label":"Mythical","value":"mythical"},{"label":"Legendary","value":"legendary"},{"label":"Immortal","value":"immortal"},{"label":"Galaxy","value":"galaxy"},{"label":"Common","value":"common"},{"label":"Uncommon","value":"uncommon"},{"label":"Epic","value":"epic"},{"label":"Unique","value":"unique"}],"freeSolo":true},{"id":"books","label":"Books","type":"list","required":true,"valueByFieldId":"bookType","addLabel":"Add book","fields":[{"key":"book","label":"Book","type":"input","inputType":"text","placeholder":"example: voodoo"},{"key":"minLevel","label":"Min book level","type":"input","inputType":"number","placeholder":"optional"},{"key":"pv","label":"Pv","type":"input","inputType":"number","placeholder":"optional"}]}],"collapsed":true}],"folder":"JartexProfile","banner":"https://i.ibb.co/vx7YwgdW/booksorter.png"},"code":{"code":"\nconst {script, BotMachine} = require(\"jnbot\")\n\nfunction parseBooks(bookSettings) {\n  let bookMap = {};\n  bookSettings.forEach((bookAttr) => {\n    let [pv, book, minLevel] = bookAttr.split(',');\n    book = book.trim().toLowerCase();\n    bookMap[book] = {\n      book: book.trim().toLowerCase(),\n      minLevel: parseInt(minLevel ?? '0'),\n      pv: parseInt(pv),\n    };\n  });\n  return bookMap;\n}\n\nconst ROMAIN_NUMBERS = {\n  I: 1,\n  V: 5,\n  X: 10,\n};\n\nasync function bookSorter() {\n  const scriptOptions = script.settings\n  const bookType = scriptOptions.bookType ?? 'mythical';\n  const shouldShiftClick = scriptOptions.shiftClick ?? true;\n\n  let pvFillAmount = parseInt(scriptOptions.pvFillAmount || '0');\n  if (isNaN(pvFillAmount) || pvFillAmount < 0 || pvFillAmount > 54) {\n    console.error('Invalid pvFillAmount option, using default value: 0');\n    pvFillAmount = 0;\n  }\n\n  let bookKey = Object.keys(scriptOptions).find(\n    (key) => key.startsWith(bookType) && key.endsWith('Books'),\n  );\n\n  let books = parseBooks(\n    scriptOptions.books?.[bookKey] ?? [],\n  );\n  console.log(books);\n  console.log(bookType);\n  console.log(bookKey);\n\n  const username = scriptOptions.username ?? '';\n  const giftTo = scriptOptions.giftTo ?? '';\n  const gamemode = scriptOptions.gamemode ?? 'skyblockdream';\n  main({\n    books: books,\n    bookType: bookType,\n    username: username,\n    giftTo: giftTo,\n    gamemode: gamemode,\n    pvFillAmount: pvFillAmount,\n    trashDust: scriptOptions.trashDust ?? false,\n    trashUnwantedBooks: scriptOptions.trashUnwantedBooks ?? false,\n    shouldShiftClick,\n  });\n}\n\nasync function main(options) {\n   new BotMachine(\n    [\n      {\n        name: 'Setup xp listener',\n        when: () => true,\n        run: async ({bot, botM}) => {\n          bot.on('messagestr', (msg) => {\n            if (\n              msg.toLowerCase().startsWith('(!) you do not have enough exp')\n            ) {\n              console.log('Not enough xp to buy books, stopping script...');\n              bot.end();\n              botStatemachine.stop();\n              process.nextTick(() => {\n                process.exit(0);\n              });\n            }\n          });\n        },\n        once: true,\n      },\n      {\n        name: 'Buying books',\n        when: ({bot}) =>\n          bot.currentWindow &&\n          bot.getWindowTitle().toLowerCase().includes('enchanter') &&\n          hasInventorySpace(bot), // WHen /enchanter window is opened\n        run: async ({bot}) => {\n          let slot = findContainerItem(bot, (item) => {\n            return (\n              item &&\n              itemInfo(item)\n                .name.toLowerCase()\n                .includes(options.bookType.toLowerCase())\n            );\n          })?.slot;\n          if (isNaN(slot)) {\n            console.warn(\n              'Book type with name \"' +\n                options.bookType +\n                '\" not found in window! Using default values',\n            );\n\n            if (\n              options.gamemode === 'factions' ||\n              options.gamemode.toLowerCase() === 'factions immortal'\n            ) {\n              slot =\n                {\n                  common: 10,\n                  uncommon: 11,\n                  epic: 12,\n                  unique: 14,\n                  legendary: 15,\n                  eternal: 22,\n                }[options.bookType] ?? 11;\n            } else {\n              slot =\n                {\n                  basic: 10,\n                  rare: 11,\n                  mythical: 12,\n                  legendary: 13,\n                  immortal: 14,\n                  galaxy: 15,\n                  eternal: 16,\n                }[options.bookType] ?? 10;\n            }\n          }\n          console.log('Buying ' + bot.inventory.emptySlotCount() + ' books');\n\n          let emptySlots = bot.inventory.emptySlotCount();\n          for (let i = 0; i < emptySlots; i++) {\n            bot.clickWindow(slot, 0, 0);\n            await bot.waitForTicks(1);\n          }\n          await bot.waitForTicks(5);\n          if (bot.currentWindow) {\n            bot.closeWindow(bot.currentWindow);\n            await Promise.race([\n              bot.waitForTicks(10),\n              once(bot, 'windowClose'),\n            ]);\n          }\n        },\n      },\n\n      {\n        name: 'Opening tinkering window',\n        when: ({bot}) =>\n          !bot.currentWindow &&\n          // !options.trashUnwantedBooks &&\n          bot.inventory.slots.some(\n            // Check if there's a book that we don't need in the inventory\n            (item) =>\n              item &&\n              item.name === 'book' &&\n              item.count === 1 &&\n              !filter(item) &&\n              !itemInfo(item).name.toLowerCase().includes('(right click)'), // skip the unused books\n          ),\n        run: async ({bot}) => {\n          await bot.openWindow(\n            options.trashUnwantedBooks ? '/trash' : '/tinkerer',\n          );\n        },\n      },\n      {\n        name: options.trashUnwantedBooks\n          ? 'Trashing unwanted books'\n          : 'Tinkering',\n        when: ({bot}) => {\n          const win = bot.getWindowTitle()?.toLowerCase();\n\n          return (\n            bot.currentWindow &&\n            ((!options.trashUnwantedBooks && win.includes('tinkerer')) ||\n              (options.trashUnwantedBooks &&\n                (win.includes('disposal') || win.includes('trash'))))\n          );\n        },\n        run: options.trashUnwantedBooks ? trashBooks : tinkerBooks,\n      },\n      {\n        name: 'Gifting dust',\n        when: shouldGiftDust, // if there are dye items in inventory\n        run: async ({bot}) => {\n          if (options.trashDust) {\n            await bot.transferItems.trash({\n              filter: [351, 'gunpowder'],\n            });\n          } else {\n            await bot.transferItems(2, {\n              username: options.giftTo,\n              itemFilter: (item) => item && item.type === 351,\n            });\n          }\n        },\n      },\n      {\n        name: `${options.pvFillAmount ? 'Pv got at least ' + options.pvFillAmount + ' books' : 'Pv is filled'}. Withdrawing books...`,\n        when: ({bot}) =>\n          bot.getWindowTitle()?.includes('Vault #') && containerIsFull(bot),\n        run: async ({bot, state}) => {\n          // For some reason we cannot put items from pv to inventory unless we reopen the window\n          bot.closeWindow(bot.currentWindow);\n          await bot.waitForTicks(5);\n          await bot.openWindow('/pv ' + (state.state || 1));\n\n          await withdrawBooks(bot);\n          if (bot.currentWindow) bot.closeWindow(bot.currentWindow);\n          await bot.transferItems('gift', {\n            username: options.giftTo,\n            itemFilter: filter,\n          });\n        },\n      },\n      {\n        name: 'Putting books in pv',\n        when: ({bot}) =>\n          !bot.currentWindow && bot.inventory.slots.some(filter),\n        run: async ({bot, state}) => {\n          let pvs = {};\n          for (\n            let i = bot.inventory.inventoryStart;\n            i < bot.inventory.inventoryEnd;\n            i++\n          ) {\n            const slot = bot.inventory.slots[i];\n            const book = slot && filter(slot);\n            if (!book) continue;\n            pvs[book.pv] ??= new Set();\n            pvs[book.pv].add(slot.slot - bot.inventory.inventoryStart);\n          }\n\n          for (const [pv, slots] of Object.entries(pvs)) {\n            if (bot.currentWindow) bot.closeWindow(bot.currentWindow);\n            console.log(`Opening pv ${pv} to deposit ${slots.size} books...`);\n            await bot.openWindow('/pv ' + pv);\n            state.lastPvOpened = pv;\n            if (!bot.currentWindow) {\n              console.log('Could not open pv ' + pv, 'warning');\n              continue;\n            }\n            await bot.transferItems('window', {\n              itemFilter: (item) => {\n                //  if(item) console.log(\n                //    itemInfo(item).name.toLowerCase(),\n                //    item.slot - bot.currentWindow.inventoryStart,\n                //    item.slot,\n                //    bot.currentWindow.inventoryStart\n                //  );\n                return (\n                  item &&\n                  bot.currentWindow &&\n                  slots.has(item.slot - bot.currentWindow.inventoryStart)\n                );\n              },\n              shiftClick: options.shouldShiftClick,\n            });\n            if (containerIsFull(bot)) {\n              return;\n            }\n            if (bot.currentWindow) bot.closeWindow(bot.currentWindow);\n          }\n        },\n      },\n\n      {\n        name: 'Opening books',\n        when: ({bot}) =>\n          findInventoryItem(bot, bookIsEnchantment) &&\n          bot.inventory.emptySlotCount() > 0,\n        run: async ({bot, state}) => {\n          state.__Item ??= prismItem(bot.registry);\n\n          if (bot.currentWindow) {\n            bot.closeWindow(bot.currentWindow);\n            await bot.waitForTicks(5);\n          }\n\n          const book = findInventoryItem(bot, bookIsEnchantment);\n          // Book is in hotbar\n          const handSlot = bot.getEquipmentDestSlot('hand').slot;\n          if (book.slot !== handSlot) {\n            if (\n              book.slot <= bot.inventory.hotbarStart &&\n              book.slot >= bot.inventory.hotbarStart + 9\n            ) {\n              bot.setQuickBarSlot(book.slot);\n              await bot.waitForTicks(1);\n              // bot.activateItem();\n            } else {\n              bot.openInventory();\n              // let confirmation = bot.inventory.requiresConfirmation;\n              // bot.inventory.requiresConfirmation = true;\n              await Promise.race([bot.equip(book, 'hand'), sleep(1500)]);\n              // bot.inventory.requiresConfirmation = confirmation;\n            }\n          }\n          const bookToOpenCount = Math.min(\n            book.count,\n            bot.inventory.emptySlotCount() + 1, // +1 for the book in hand\n          );\n\n          for (let i = 0; i < bookToOpenCount; i++) {\n            if (bot.supportFeature('useItemWithBlockPlace')) {\n              // bot.usingHeldItem = true\n\n              // let botbarslot = bot.getEquipmentDestSlot('hand').slot\n\n              if (!bot.heldItem) {\n                console.error(\n                  \"[ERROR] Activating item without heldItem, this isn't supposed to happen\",\n                );\n                return;\n              }\n              bot._client.write('block_place', {\n                location: new Vec3(-1, -1, -1),\n                direction: -1,\n                heldItem: targets.__Item.toNotch(bot.heldItem),\n                cursorX: 0,\n                cursorY: 0,\n                cursorZ: 0,\n              });\n              await bot.waitForTicks(Math.floor(10 * Math.random()));\n            } else {\n              bot.activateItem();\n            }\n            await bot.waitForTicks(3);\n          }\n          await bot.waitForTicks(80);\n        },\n      },\n\n      {\n        name: 'Opening enchanter window',\n        when: ({bot}) => bot.inventory.emptySlotCount() > 0,\n        run: async ({bot}) => {\n          await bot.openWindow('/enchanter');\n        },\n      },\n      {\n        name: 'Idling',\n        when: () => true,\n        run: () => {},\n      },\n    ],\n    {\n      \n      options: {\n        username: options.username,\n      },\n      join: {gamemode: options.gamemode},\n    },\n  ).start();\n\n  function filter(item) {\n    if (!item || item.name !== 'book') return null;\n\n    let enchantName = itemInfo(item)?.name?.replace(/§./g, '');\n\n    if (!enchantName || enchantName.includes(' (Right Click)')) return null;\n    let enchantLvl = enchantName.match(/ ([A-Z]+)$/)?.[1];\n    if (!enchantLvl) {\n      // it can also be a numeric level\n      enchantLvl = parseInt(enchantName.match(/ ([0-9]+)$/)?.[1] ?? '');\n      if (isNaN(enchantLvl)) enchantLvl = null;\n    }\n    enchantLvl ??= 'I';\n    enchantName = enchantName.replace(/ ([A-Z]+|[0-9]+)$/, '').toLowerCase();\n\n    if (options.books.hasOwnProperty(enchantName)) {\n      const book = options.books[enchantName];\n      if (book.minLevel === 0) return book;\n      let enchantLevel = roman_to_Int(enchantLvl);\n      if (isNaN(enchantLevel))\n        console.error(\n          'Could not find correct enchantment level',\n          enchantName,\n          enchantLevel,\n        );\n      if (enchantLevel < book.minLevel) return null;\n      return book;\n    }\n    return null;\n  }\n\n  async function trashBooks(bot) {\n    await bot.itemTransfer.trash({\n      filter: (item) => {\n        const book = filter(item);\n        return book === null;\n      },\n      keep: false,\n    });\n  }\n  async function tinkerBooks(bot) {\n    // let booksToTinker = bot.inventory.slots\n    //   .filter(\n    //     (item) =>\n    //       item &&\n    //       item.name === 'book' &&\n    //       item.count === 1 &&\n    //       !filter(item) &&\n    //       !itemInfo(item).name.toLowerCase().includes('(right click)'),\n    //   )\n    //   .slice(0, 23)\n    //   .map((item) => item.slot - bot.inventory.inventoryStart);\n    // if (booksToTinker.length === 0) return;\n    if (!bot.currentWindow) return;\n    let tinkered = 0;\n    for (\n      let i = bot.currentWindow.inventoryStart;\n      i < (bot.currentWindow?.inventoryEnd ?? 0);\n      i++\n    ) {\n      if (!bot.currentWindow) break;\n      const slot = bot.currentWindow.slots[i];\n      if (slot && !filter(slot)) {\n        bot.clickWindow(i, 0, 0);\n        tinkered++;\n        await bot.waitForTicks(1);\n        if (tinkered >= 23) break;\n      }\n    }\n    if (!bot.currentWindow) return;\n    // Find confirm button\n    let confirmSlot = 0;\n    for (let i = 0; i < bot.currentWindow.inventoryStart; i++) {\n      const slot = bot.currentWindow.slots[i];\n      if (!slot) continue;\n      const { name } = bot.itemInfo(slot);\n      if (name.toLowerCase().includes('confirm')) {\n        confirmSlot = i;\n        break;\n      }\n    }\n    bot.clickWindow(confirmSlot, 0, 0);\n\n    await Promise.race([bot.waitForTicks(10), once(bot, 'windowClose')]);\n    await bot.waitForTicks(5);\n  }\n\n  function containerIsFull(bot) {\n    if (!bot.currentWindow) return false;\n    let maxFullSlots =\n      options.pvFillAmount ?? bot.currentWindow?.inventoryStart;\n    for (let i = 0; i < maxFullSlots; i++) {\n      if (!bot.currentWindow.slots[i]) return false;\n    }\n    return true;\n  }\n\n  function shouldGiftDust({bot}) {\n    if (bot.currentWindow) return false;\n\n    let count = 0;\n    for (let i = 0; i < bot.inventory.slots.length; i++) {\n      if (bot.inventory.slots[i]?.type === 351) {\n        count++;\n        if (count > 10) return true;\n      }\n    }\n\n    return false;\n  }\n\n  function findInventoryItem(bot, filter) {\n    const window = bot.currentWindow ?? bot.inventory;\n    for (let i = window.inventoryStart; i < window.inventoryEnd; i++) {\n      if (window.slots[i] && filter(window.slots[i])) return window.slots[i];\n    }\n    return null;\n  }\n\n  function findContainerItem(bot, filter) {\n    for (let i = 0; i < bot.currentWindow.inventoryStart; i++) {\n      if (filter(bot.currentWindow.slots[i])) return bot.currentWindow.slots[i];\n    }\n    return null;\n  }\n\n  function bookIsEnchantment(item) {\n    return (\n      item &&\n      item.name === 'book' &&\n      itemInfo(item).name.includes('(Right Click)')\n    );\n  }\n\n  function containerHasItems(bot) {\n    if (!bot.currentWindow) return false;\n    for (\n      let i = 0;\n      i < (options.pvFillAmount || bot.currentWindow.inventoryStart);\n      i++\n    ) {\n      if (bot.currentWindow.slots[i]) return true;\n    }\n    return false;\n  }\n\n  async function withdrawBooks(bot) {\n    let space = bot.inventory.emptySlotCount();\n    if (space === 0) return console.log('No space');\n    await bot.waitForTicks(5);\n    if (!bot.currentWindow) return;\n\n    if (options.shouldShiftClick) {\n      const win = bot.currentWindow;\n      for (let i = 0; i < win.inventoryStart; i++) {\n        const slot = win.slots[i];\n        if (!slot || slot.name !== 'book') continue;\n        bot.clickWindow(i, 0, 1);\n        await bot.waitForTicks(2);\n\n        if (bot.inventory.emptySlotCount() === 0 || !bot.currentWindow) {\n          return;\n        }\n      }\n      return;\n    }\n\n    let slot = 0;\n    let destSlot = bot.currentWindow.inventoryStart;\n    while (\n      space > 0 &&\n      slot < bot.currentWindow.inventoryStart &&\n      destSlot < bot.currentWindow.inventoryEnd\n    ) {\n      while (slot < bot.currentWindow.inventoryStart) {\n        const s = bot.currentWindow.slots[slot];\n        if (s && s.name === 'book') break;\n        slot++;\n      }\n      if (slot === bot.currentWindow.inventoryStart) return;\n\n      for (destSlot; destSlot < bot.currentWindow.inventoryEnd; destSlot++) {\n        if (!bot.currentWindow.slots[destSlot]) {\n          break;\n        }\n      }\n\n      if (destSlot === bot.currentWindow.inventoryEnd) {\n        console.log('No space in inventory');\n        return;\n      }\n\n      console.log(`Moving book from ${slot} to ${destSlot}`);\n\n      bot.moveSlotItem(slot, destSlot);\n      space--;\n      slot++;\n      destSlot++;\n      await bot.waitForTicks(5);\n    }\n  }\n\n  function hasInventorySpace(bot) {\n    for (\n      let i = bot.inventory.inventoryStart;\n      i < bot.inventory.inventoryEnd;\n      i++\n    ) {\n      if (!bot.inventory.slots[i]) return true;\n    }\n    return false;\n  }\n}\n\nfunction roman_to_Int(str1) {\n  if (typeof str1 === 'number') return str1;\n  if (str1 == null) return -1;\n\n  let num = ROMAIN_NUMBERS[str1.charAt(0)] ?? -1;\n  let pre, curr;\n\n  for (let i = 1; i < str1.length; i++) {\n    curr = ROMAIN_NUMBERS[str1.charAt(i)] ?? -1;\n    pre = ROMAIN_NUMBERS[str1.charAt(i - 1)] ?? -1;\n    if (curr <= pre) {\n      num += curr;\n    } else {\n      num = num - pre * 2 + curr;\n    }\n  }\n\n  return num;\n}\n\nfunction sleep(x) {\n  return new Promise((resolve) => setTimeout(resolve, x));\n}\n\n\nbookSorter()"},"signature":""}