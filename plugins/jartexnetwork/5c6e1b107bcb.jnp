{"info":{"name":"Gkit Collector","description":"Joins with your alts and collects your gkits and gifts them to your main account. ","editedAt":1780008717524,"uploadedAt":null,"createdAt":1779914783258,"public":false,"type":"private","language":"js","scriptType":"action","flags":0,"downloads":0,"theme":{"primaryColor":"#2193b0","secondaryColor":"#6dd5ed","accentColor":"#2193b0","gradientStart":"#2193b0","gradientEnd":"#6dd5ed","tagColor":"#6dd5ed"},"settings":{"ignoreItems":{"0":"pickaxe","Factions Immortal":["pickaxe","test"],"SkyblockDream":["kook"]},"gamemode":"SkyblockDream","ignoreGkits":{"Factions Immortal":["keys"],"Survival":["keys","fds"],"SkyblockDream":["keys","dsfs","dd"]},"withGkits":{"SkyblockDream":false}},"pluginId":"mpojb0gpxnn024s3i2","banner":"https://i.ibb.co/q32JYysT/gkitcollector.png","config":[{"name":"General","options":[{"id":"gamemode","label":"Gamemode","type":"gamemodeSelect","required":true}],"collapsed":false},{"name":"Transfer","options":[{"id":"itemTransfer","label":"Item transfer mode","type":"select","required":true,"options":[{"label":"Keep items","value":"keep"},{"label":"Using /trade","value":"trade"},{"label":"Using /gift","value":"gift"},{"label":"/trade with keys","value":"tradeWithKeys"}]},{"id":"username","label":"Transfer items to","type":"altSelect","clearable":true,"freeSolo":true},{"id":"transferOnNearFull","label":"Transfer on near full","type":"switch","tooltip":"If enabled, the bot will transfer its items when there are less than 8 empty slots. This prevents the bot from dumping its gkits on the floor.","defaultValue":true},{"id":"keyTypes","label":"Select keys (only for /trade with keys)","type":"multiSelect","tooltip":"To determine the amount of keys to trade, specify the number of times the bot should click on each key. Keep in mind that trading a larger quantity may result in a longer transferring time. Use the format <key type>,<amount> e.g. vote,10 means the bot tries to find the vote key slot and click 10 times on it.","options":["vote,10","rare,5","ultra,2","god,1"],"defaultValue":["vote,10","rare,5","ultra,2","god,1"],"freeSolo":true},{"id":"forceTradeKeys","label":"Force trade keys (only for /trade with keys)","type":"switch","tooltip":"The script joins with the account specified in 'Transfer items to' and automatically accepts trades, storing the items in its pv. This feature is only available for the 'Trade with Keys' and 'Using /trade' transfer modes."}],"collapsed":true},{"name":"Alts","options":[{"id":"altRange","label":"Alt range","type":"altRange","valueByFieldId":"gamemode"},{"id":"withTags","label":"Alt groups","type":"tagsSelect","valueByFieldId":"gamemode"},{"id":"ignoreAlts","label":"Ignore alts","type":"altsSelect","valueByFieldId":"gamemode"},{"id":"withGkits","label":"Skip alts with no gkits","type":"switch","valueByFieldId":"gamemode","defaultValue":false,"labelChecked":"Gkits only alts","labelUnchecked":"All alts"}],"collapsed":true},{"name":"Ignore","options":[{"id":"ignoreItems","label":"Ignore items","type":"multiSelect","tooltip":"The bot will not attempt to transfer these items. For example, to prevent the bot from trying to gift an untradable pickaxe in OP Prison, add 'pickaxe' to the ignore items. The value is case-insensitive and must be a substring of the item name. Add items by typing the item name and pressing Enter.","valueByFieldId":"gamemode","freeSolo":true},{"id":"ignoreGkits","label":"Ignore Gkits","type":"multiSelect","valueByFieldId":"gamemode","freeSolo":true}],"collapsed":true},{"name":"Other","options":[{"id":"executeCommandAtStart","label":"Execute command before collecting","type":"input","tooltip":"If a value is set, the bot will execute this command before collecting gkits. For example `/spawn` would make the bot go to /spawn and start collecting gkits.","inputType":"text","placeholder":"/spawn"}],"collapsed":true}],"folder":"JartexProfile"},"codeObf":"","signature":""}