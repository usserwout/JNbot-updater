{"info":{"name":"Gkit Collector","description":"Joins with your alts and collects your gkits and gifts them to your main account. ","editedAt":1780008717524,"uploadedAt":null,"createdAt":1779914783258,"public":false,"type":"private","language":"js","scriptType":"action","flags":0,"downloads":0,"theme":{"primaryColor":"#2193b0","secondaryColor":"#6dd5ed","accentColor":"#2193b0","gradientStart":"#2193b0","gradientEnd":"#6dd5ed","tagColor":"#6dd5ed"},"settings":{"ignoreItems":{"0":"pickaxe","Factions Immortal":["pickaxe","test"],"SkyblockDream":["kook"]},"gamemode":"SkyblockDream","ignoreGkits":{"Factions Immortal":["keys"],"Survival":["keys","fds"],"SkyblockDream":["keys","dsfs","dd"]},"withGkits":{"SkyblockDream":false}},"pluginId":"mpojb0gpxnn024s3i2","banner":"https://i.ibb.co/q32JYysT/gkitcollector.png","config":[{"name":"General","options":[{"id":"gamemode","label":"Gamemode","type":"gamemodeSelect","required":true}],"collapsed":false},{"name":"Transfer","options":[{"id":"itemTransfer","label":"Item transfer mode","type":"select","required":true,"options":[{"label":"Keep items","value":"keep"},{"label":"Using /trade","value":"trade"},{"label":"Using /gift","value":"gift"},{"label":"/trade with keys","value":"tradeWithKeys"}]},{"id":"username","label":"Transfer items to","type":"altSelect","clearable":true,"freeSolo":true},{"id":"transferOnNearFull","label":"Transfer on near full","type":"switch","tooltip":"If enabled, the bot will transfer its items when there are less than 8 empty slots. This prevents the bot from dumping its gkits on the floor.","defaultValue":true},{"id":"keyTypes","label":"Select keys (only for /trade with keys)","type":"multiSelect","tooltip":"To determine the amount of keys to trade, specify the number of times the bot should click on each key. Keep in mind that trading a larger quantity may result in a longer transferring time. Use the format <key type>,<amount> e.g. vote,10 means the bot tries to find the vote key slot and click 10 times on it.","options":["vote,10","rare,5","ultra,2","god,1"],"defaultValue":["vote,10","rare,5","ultra,2","god,1"],"freeSolo":true},{"id":"forceTradeKeys","label":"Force trade keys (only for /trade with keys)","type":"switch","tooltip":"The script joins with the account specified in 'Transfer items to' and automatically accepts trades, storing the items in its pv. This feature is only available for the 'Trade with Keys' and 'Using /trade' transfer modes."}],"collapsed":true},{"name":"Alts","options":[{"id":"altRange","label":"Alt range","type":"altRange","valueByFieldId":"gamemode"},{"id":"withTags","label":"Alt groups","type":"tagsSelect","valueByFieldId":"gamemode"},{"id":"ignoreAlts","label":"Ignore alts","type":"altsSelect","valueByFieldId":"gamemode"},{"id":"withGkits","label":"Skip alts with no gkits","type":"switch","valueByFieldId":"gamemode","defaultValue":false,"labelChecked":"Gkits only alts","labelUnchecked":"All alts"}],"collapsed":true},{"name":"Ignore","options":[{"id":"ignoreItems","label":"Ignore items","type":"multiSelect","tooltip":"The bot will not attempt to transfer these items. For example, to prevent the bot from trying to gift an untradable pickaxe in OP Prison, add 'pickaxe' to the ignore items. The value is case-insensitive and must be a substring of the item name. Add items by typing the item name and pressing Enter.","valueByFieldId":"gamemode","freeSolo":true},{"id":"ignoreGkits","label":"Ignore Gkits","type":"multiSelect","valueByFieldId":"gamemode","freeSolo":true}],"collapsed":true},{"name":"Other","options":[{"id":"executeCommandAtStart","label":"Execute command before collecting","type":"input","tooltip":"If a value is set, the bot will execute this command before collecting gkits. For example `/spawn` would make the bot go to /spawn and start collecting gkits.","inputType":"text","placeholder":"/spawn"}],"collapsed":true}],"folder":"JartexProfile"},"code":{"code":"const {script, BotMachine} = require(\"jnbot\")\n\n\nasync function main(bot, scriptOptions) {\n  let hasInvalidSettings = false\n  if (scriptOptions.itemTransfer !== \"keep\" && !scriptOptions.username) {\n    script.optionError({ field: \"username\", message: \"Enter an account to transfer the gkits to\" })\n    hasInvalidSettings = true\n  }\n\n  if (scriptOptions.executeCommandAtStart?.length &&\n    !scriptOptions.executeCommandAtStart.startsWith('/')) {\n    script.optionError({ field: \"username\", message: \"Enter an account to transfer the gkits to\" })\n    hasInvalidSettings = true\n  }\n\n  if (hasInvalidSettings) {\n    script.stop()\n  }\n\n  scriptOptions.ignoreItems ??= []\n  scriptOptions.keys ??= []\n  scriptOptions.ignoreGkits ??= []\n  const gamemode = scriptOptions.gamemode\n\n  const reminder = (await script.getReminders()).find((r) => r.reminderId === gamemode)\n  if(!reminder && scriptOptions.gamemode) {\n    script.addReminder({name: scriptOptions.gamemode + \" Gkits\", cooldown: 1000 * 60 * 60 * 24 * 7, reminderId: gamemode})\n  } else if (reminder.isCompleted()) {\n    reminder.reset()\n  }\n\n\n  \n\n\n  return new Promise((resolve) => {\n    new BotMachine([\n      {\n        name: 'Executing ' + scriptOptions.executeCommandAtStart,\n        when: ({ state }) => scriptOptions.executeCommandAtStart && !state.__executedCommand,\n        run: async ({ bot, state }) => {\n          state.__executedCommand = true\n          bot.chat(state.executeCommandAtStart)\n          await bot.waitForTicks(10);\n        }\n      },\n      {\n        name: \"Transfering gkits\",\n        when: ({ bot, state }) => state.has_collected ||\n          (scriptOptions.transferOnNearFull &&\n            bot.inventory.emptySlotCount() < 8),\n        run: async ({ bot, state, machine }) => {\n          if (bot.currentWindow) {\n            bot.closeWindow(bot.currentWindow);\n            await bot.waitForTicks(5);\n          }\n\n          await bot.transferItems(scriptOptions.itemTransfer, {\n            username: scriptOptions.username,\n            ignore: ['clock'],\n            keys: scriptOptions.keys,\n            forceTradeKeys: scriptOptions.forceTradeKeys,\n            itemFilter:\n              scriptOptions.ignoreItems.length > 0\n                ? (item) => {\n                  const itemName = item.name\n                    .toLowerCase()\n                    .replace(/§./g, '');\n                  return !scriptOptions.ignoreItems.some((e) =>\n                    itemName.includes(e),\n                  );\n                }\n                : undefined,\n          });\n\n          if (state.has_collected) {\n            console.log(\"[\" + bot.username + \"] Gkits transferred, stopping bot\");\n            machine.stop();\n          }\n        }\n      },\n      {\n        name: \"Opening gkit menu\",\n        when: ({ bot, state }) => !state.has_collected && !bot.currentWindow,\n        run: async ({ bot }) => {\n          await bot.openWindow('/gkit', { timeout: 10_000 });\n          if (!bot.currentWindow) {\n            console.error(\"[\" + bot.username + \"] No gkit window opened, bot is probably bugged in hub. \");\n            await bot.join(scriptOptions.gamemode)\n            if (bot.currentWindow) {\n              bot.closeWindow(bot.currentWindow);\n              console.log('Closing current window: ' + bot.getWindowTitle());\n              await bot.onceWithTimeout('windowClose', 5);\n            }\n          }\n        }\n      },\n      {\n        name: \"Clicking on gkit\",\n        when: ({ bot, state }) => {\n          const winName = bot.getWindowTitle().toLowerCase();\n          return (\n            !state.has_collected &&\n            (winName.includes('gkit selector') ||\n              winName.includes('gkits') ||\n              winName.includes('classes')) ||\n            winName.includes('global kits') /* skymines */\n          );\n        },\n        run: async ({ bot, state }) => {\n          let gkitSlot;\n          let gkitWindowCount = 0;\n          while (\n            !gkitSlot &&\n            gkitWindowCount < bot.currentWindow.inventoryStart\n          ) {\n            const slot = bot.currentWindow.slots[gkitWindowCount];\n            gkitWindowCount++;\n            if (!slot) continue;\n            let { name, info } = bot.itemInfo(slot);\n            if (!info || !name) continue;\n            info = info.replace(/§./g, '').toLowerCase();\n            name = name.replace(/§./g, '');\n\n            if (\n              info.includes('you do not have permission!') ||\n              info.includes('you do not own this') ||\n              info.includes('\\nlocked\\n') ||\n              info.includes(\"you can claim this class again in\") ||\n              info.includes('you can claim this gkit again in')\n            )\n              continue;\n            let name_ = name.toLowerCase();\n\n            if (\n              scriptOptions.ignoreGkits.find((gkit) =>\n                gkit.toLowerCase().includes(name_),\n              )\n            ) {\n              console.log('Skipping gkit: ' + name);\n            } else if (info.includes('cooldown over in')) {\n              let cooldown = info\n                .match(/cooldown over [^!]*!/)?.[0]\n                ?.replace('cooldown over in ', '');\n\n              if (cooldown) {\n                console.log(\n                  `[${bot.username}] ${name} is ready in ${cooldown}`,\n                  'warning',\n                );\n              }\n            } else if (\n              info.includes('click to redeem this ') ||\n              info.includes('you can claim this ') ||\n              info.includes('click here to redeem this ')\n            ) {\n              gkitSlot = slot;\n              console.log(`[${bot.username}] Claiming gkit: ${name}`);\n            }\n          }\n\n          if (gkitSlot) {\n            bot.clickWindow(gkitSlot.slot, 0, 0);\n            await bot.waitForTicks(1)\n          } else {\n            // Check if there are more gkit pages.\n            const nextGkitPageSlot = bot.getNextGkitPageSlot();\n            if (nextGkitPageSlot >= 0) {\n              console.log(`[${bot.username}] Next page found, clicking on slot ${nextGkitPageSlot}...`);\n              bot.clickWindow(nextGkitPageSlot, 0, 0);\n              await bot.waitForTicks(10);\n              return;\n            }\n\n            state.has_collected = true;\n            console.log(`[${bot.username}] No more gkits to claim`);\n            if (bot.currentWindow) bot.closeWindow(bot.currentWindow);\n          }\n        }\n      },\n\n      {\n          name: 'Closing incorrect window',\n          when: ({state}) => !state.has_collected,\n          action: async ({bot}) => {\n            bot.closeWindow(bot.currentWindow);\n            await bot.waitForTicks(10);\n          },\n        },\n\n\n    ], {\n      bot,\n      join: { login: true, gamemode: scriptOptions.gamemode, joinOptions: bot.alt },\n      state: { has_collected: false }\n    }).onFinish(() => {\n\n      resolve()\n    }).start()\n\n  })\n\n\n}\n\nfunction sleep(x) {\n  return new Promise(r => setTimeout(r, x))\n}"},"signature":""}