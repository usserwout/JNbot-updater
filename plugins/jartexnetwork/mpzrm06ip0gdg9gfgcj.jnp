{"info":{"name":"Gkit upgrader","description":"Upgrade all your gkits","editedAt":1780594800673,"uploadedAt":null,"createdAt":1780593860970,"public":false,"type":"private","language":"js","scriptType":"action","flags":0,"downloads":0,"theme":{"primaryColor":"#2193b0","secondaryColor":"#6dd5ed","accentColor":"#2193b0","gradientStart":"#2193b0","gradientEnd":"#6dd5ed","tagColor":"#6dd5ed"},"settings":{},"pluginId":"mpzrm06ip0gdg9gfgcj","banner":"https://i.ibb.co/BHhNZGW7/gkitupgrader.png","config":[{"name":"General","options":[{"id":"gamemode","label":"Gamemode","type":"gamemodeSelect","required":true},{"id":"altRange","label":"Alt range","type":"altRange"}],"collapsed":false},{"name":"Ignore","options":[{"id":"ignoreAlts","label":"Ignore alts","type":"altsSelect","valueByFieldId":"gamemode"},{"id":"alt_filter","label":"Skip alts with no gkits","type":"switch","defaultValue":false}],"collapsed":true}],"folder":"JartexProfile"},"code":{"code":"\nconst { BotMachine, script } = require(\"jnbot\")\n\nasync function main(bot) {\n  const options = script.options\n\n\n  return new Promise((resolve) => {\n    new BotMachine([{\n      name: 'Opening gkit window',\n      when: ({ bot }) => !bot.currentWindow,\n      run: async ({ bot }) => {\n        await bot.openWindow('/gkit');\n      },\n    },\n    {\n      name: 'Confirm upgrade',\n      when: ({ bot }) =>\n        bot.getWindowTitle().toLowerCase().includes('are you sure?'),\n      run: async ({ bot }) => {\n        for (let i = 0; i < bot.currentWindow.inventoryStart; i++) {\n          const slot = bot.currentWindow.slots[i];\n          if (!slot) continue;\n          const { info } = bot.itemInfo(slot);\n          if (info.toLowerCase().includes('confirm this')) {\n            bot.clickWindow(i, 0, 0);\n            return;\n          }\n        }\n        bot.clickWindow(11, 0, 0); // In case it didn't work\n      },\n    },\n    {\n      name: 'Clicking on gkit upgrade item',\n      when: ({ bot }) => {\n        let a = bot.getWindowTitle().toLowerCase();\n        return (\n          a.includes('gkit selector') ||\n          ((a.includes('gkits') || a.includes('classes')) &&\n            !a.includes('upgrade'))\n        );\n      },\n      run: async ({ bot }) => {\n        for (let i = 0; i < bot.currentWindow.inventoryStart; i++) {\n          const item = bot.currentWindow.slots[i];\n          if (!item) continue;\n          const name = bot.itemInfo(item)?.name?.toLowerCase();\n          if (\n            name.includes('upgrade gkits') ||\n            name.includes('upgrade class')\n          ) {\n            bot.clickWindow(i, 0, 0);\n            break;\n          }\n        }\n      },\n    },\n    {\n      name: 'Upgrading gkits',\n      when: () => true,\n      action: async ({ bot, botMachine }) => {\n        // find upgrade item\n        let upgradeItem;\n        for (let i = 0; i < bot.currentWindow.inventoryStart; i++) {\n          const slot = bot.currentWindow.slots[i];\n          // eslint-disable-next-line no-continue\n          if (!slot) continue;\n          const { name, info } = bot.itemInfo(slot);\n          if (name.trim().length === 0) break;\n          // eslint-disable-next-line no-continue\n          if (info.toLowerCase().includes('max level')) continue;\n          const a = /\\(([0-9]+)\\/([0-9]+)\\)/.exec(info);\n          // eslint-disable-next-line no-continue\n          if (!a) continue;\n          // eslint-disable-next-line @typescript-eslint/naming-convention\n          const [_, currentLevel, maxLevel] = a;\n          if (Number(currentLevel) < Number(maxLevel)) continue;\n          console.log(\n            `[${alt.username}] Upgrading ` +\n            name.replace(/§./g, '') +\n            ' to ' +\n            (Number(maxLevel) + 1),\n            'success',\n          );\n          upgradeItem = i;\n          break;\n        }\n        if (isNaN(upgradeItem)) {\n          if (bot.currentWindow) bot.closeWindow(bot.currentWindow);\n          console.log(\n            `${alt.username}: Finished upgrading gkits`,\n            'success',\n          );\n          botMachine.stop(); // We can't do this because botStatemachine is not always initialized\n\n        } else {\n          bot.clickWindow(upgradeItem, 0, 0);\n        }\n      },\n    },], {\n      state: { has_collected: false },\n      bot,\n      options: { username: bot.username },\n      join: { gamemode: options.gamemode, },\n    }).onFinish(() => {\n      resolve()\n    }).start()\n  })\n}\n"},"signature":""}