{"info":{"name":"scriptRunner","description":"Auto start a script like kit collector every x hours","editedAt":1752060696329,"uploadedAt":null,"createdAt":1751307759291,"public":false,"type":"private","language":"js","scriptType":"script","flags":0,"downloads":0,"theme":{"primaryColor":"#58a5a7","secondaryColor":"#2d604d","accentColor":"#3c7e6b","gradientStart":"#58a5a7","gradientEnd":"#2d604d","tagColor":"default"},"banner":"https://i.ibb.co/cXgnKDPm/Chat-GPT-Image-29-mei-2025-18-26-57.png","settings":{"script":"kit collector","inverval":"61","runOnStart":true,"logInterval":30},"config":[{"name":"General","options":[{"id":"script","label":"Script","type":"select","tooltip":"The script that will be activated every x minutes","options":[{"label":"kit collector","value":"kit collector"},{"label":"gkit collector","value":"gkit collector"}],"clearable":false,"freeSolo":true},{"id":"inverval","label":"Interval (in minutes)","type":"input","tooltip":"The amount of minutes before running the script again","inputType":"number"},{"id":"runOnStart","label":"Run the script when plugin starts","type":"switch","labelChecked":"Run plugin on start","labelUnchecked":"Start cooldown on start"},{"id":"logInterval","label":"Log interval (in minutes)","type":"slider","tooltip":"Send a log message every x minutes that tells you when the next collect is going to be.","min":5,"max":60,"step":5}],"collapsed":false}],"pluginId":"scriptRunner","folder":"usefull"},"code":{"code":"/**\n * This plugin runs a script (like \"gkit collector\" or \"kit collector\") in an interval of x hours. \n * Useful for collecting kits with a cooldown of 1 hour \n * Note: change the settings by clicking on the plugin > setting, do not change the code!\n */\n\nconst SCRIPT = script.settings?.script || \"kit collector\"\n\nconst INTERVAL =  60_000  * (parseInt(script.settings?.inverval) || 61)    // = 1hour and 1 minute |  Run script every hour\n                                 // It's better to make it a little bit longer than the cooldown to ensure the cooldown has finished.\n\nconst RUN_ON_START = script.settings?.runOnStart ??  true        // Run the script as soon as you start the plugin (if set to false, the script runs after INTERVAL ms)\n\nconst LOG_INTERVAL =  60_000 * (parseInt(script.settings?.logInterval) || 5)  // Log a message containing when the next run will be (default 5 min)\n\n\n\n// *************************************************************************************** \\\\\n\n\nfunction run() {\n  console.log(\"======================= Running: \" + SCRIPT + \" =======================\")\n  script.stopScript({\n    name: SCRIPT\n  })\n\n\n  script.startScript({\n    name: SCRIPT,                                   // Start plugin by plugin name\n    quitOnExit: false                               // Exit current plugin when script has finished\n  })\n\n}\n\nsetInterval(run, INTERVAL)\nrun()\n\n\nlet count = 0\n\nif(LOG_INTERVAL > 1000) setInterval(() => {\n  count++\n  const t = INTERVAL - LOG_INTERVAL * count\n  if (t <= 0) return count = 0\n  console.log(Math.floor(t / 60_000) + \" minutes before next collect\")\n}, LOG_INTERVAL) // Show a log message when the next collect will be (default every 5min)\n"},"signature":""}